{
  "name": "software-testing-assignment",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "mocha \"test/**/*.test.js\"",
    "coverage": "c8 --exclude \"src/.internal/**\" --reporter text --reporter lcov npm test"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0"
  },
  "nyc": {
    "all": true,
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "src/.internal/**",
      "test/**"
    ],
    "extension": [
      ".js"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "report-dir": "./coverage"
  }
}
